# Copy this file to .env and fill in real values.
# .env is git-ignored and must never be committed.

# ----- PostgreSQL (used by docker-compose and the app) -----
POSTGRES_USER=marketpulse
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=marketpulse
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ----- Application connection string (built from the values above) -----
DATABASE_URL=postgresql+psycopg://marketpulse:change_me_locally@localhost:5432/marketpulse
